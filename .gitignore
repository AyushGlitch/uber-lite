# .gitignore for a Spring Boot (Java) project
# See https://github.com/github/gitignore for templates

# Compiled class files
*.class

# Log files
*.log
logs/

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

# Maven
/target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties

# Gradle
/.gradle/
/build/
!gradle/wrapper/gradle-wrapper.jar
!gradle-wrapper.jar

# Gradle Wrapper
/gradle-wrapper.jar
/gradle/wrapper/gradle-wrapper.properties

# Wrapper scripts
mvnw
mvnw.cmd
gradlew
gradlew.bat

# IntelliJ IDEA
/.idea/
*.iml
*.iws
*.ipr
/out/

# Eclipse
.classpath
.project
.settings/

# NetBeans
/nbproject/private/
/build/
/nbbuild/
/dist/

# VS Code
.vscode/

# OS generated files
.DS_Store
Thumbs.db
ehthumbs.db

# Environment variables / secret files
.env
.env.*
*.local.properties
secrets.yml
secrets/

# Spring Boot
# (ignore logs and PID files created at runtime)
spring.log
*.pid
hs_err_pid*

# Test / reports
/surefire-reports/
/failsafe-reports/
/coverage/
/test-output/

# Generated sources
/generated-sources/
/generated-test-sources/

# IDE and build tool metadata
/.idea/
*.log
*.tmp

# Docker
docker-compose.override.yml

# Others
/repl_history

# Keep this file in repo to avoid committing IDE/build artifacts

